{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Qwen15B DeepSeek Pairwise Judge Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "winner",
    "score_a",
    "score_b",
    "confidence",
    "rationale"
  ],
  "properties": {
    "winner": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "tie"
      ]
    },
    "score_a": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "score_b": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    }
  }
}
